{
  "type": "module",
  "name": "acupatas-main",
  "description": "Demo App with Routing built-in (recommended)",
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=15.0.0"
  },
  "trustedDependencies": [
    "sharp"
  ],
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.server": "vite build -c adapters/express/vite.config.ts",
    "dev": "vite --mode ssr",
    "dev.custom": "CUSTOM_CONFIG=true vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "lint:manual": "eslint src/**/*.{ts,tsx,js,jsx}",
    "lint:fix": "eslint src/**/*.{ts,tsx,js,jsx} --fix",
    "preview": "qwik build preview && vite preview",
    "deploy": "node scripts/deploy.js",
    "serve": "node server/entry.express",
    "start": "vite --open --mode ssr",
    "qwik": "qwik"
  },
  "devDependencies": {
    "@builder.io/qwik": "latest",
    "@builder.io/qwik-city": "latest",
    "@eslint/js": "^9.39.1",
    "@qwikdev/pwa": "workspace:../",
    "@tailwindcss/vite": "^4.0.0",
    "@types/compression": "^1.7.2",
    "@types/eslint": "latest",
    "@types/express": "^4.17.19",
    "@types/leaflet": "^1.9.6",
    "@types/node": "latest",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "@vite-pwa/assets-generator": "latest",
    "compression": "^1.7.4",
    "dotenv": "^16.3.2",
    "eslint": "latest",
    "eslint-plugin-qwik": "^1.17.2",
    "fast-glob": "latest",
    "globals": "^16.5.0",
    "h3": "^1.15.3",
    "prettier": "latest",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.0.0",
    "typescript": "latest",
    "typescript-eslint": "^8.46.3",
    "undici": "latest",
    "vite": "latest",
    "vite-imagetools": "latest",
    "vite-tsconfig-paths": "latest"
  },
  "dependencies": {
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/poppins": "^5.2.7",
    "@fontsource/space-grotesk": "^5.2.10",
    "@googleapis/calendar": "latest",
    "@langchain/anthropic": "latest",
    "@langchain/community": "latest",
    "@langchain/core": "latest",
    "@langchain/langgraph": "latest",
    "@langchain/openai": "latest",
    "@libsql/client": "latest",
    "@modular-forms/qwik": "^0.29.1",
    "@qwik-ui/headless": "^0.7.4",
    "@qwik.dev/core": "latest",
    "@qwikest/icons": "^0.0.13",
    "@unpic/qwik": "latest",
    "chart.js": "^4.5.1",
    "express": "latest",
    "leaflet": "1.9.4",
    "puppeteer": "latest",
    "sharp": "latest",
    "stripe": "^20.4.1",
    "@storacha/client": "^2.1.2",
    "viem": "^2.47.6",
    "web-push": "^3.6.7"
  },
  "optionalDependencies": {
    "@img/sharp-linux-arm64": "latest",
    "@img/sharp-linux-x64": "latest",
    "@img/sharp-linuxmusl-arm64": "latest",
    "@img/sharp-linuxmusl-x64": "latest"
  }
}
